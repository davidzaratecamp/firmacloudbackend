PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=firmacloud

JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=8h

TOKEN_EXPIRES_HOURS=72

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@email.com
SMTP_PASS=tu_app_password
SMTP_FROM_NAME=FirmaCloud - Asiste Health Care
SMTP_FROM_EMAIL=tu@email.com

APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Orígenes CORS adicionales (separados por coma) — útil al acceder por IP local
# Ejemplo: CORS_ORIGINS=http://10.206.240.42:5173
CORS_ORIGINS=

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=tu_token_permanente_de_system_user
WHATSAPP_PHONE_NUMBER_ID=id_del_numero_de_telefono
WHATSAPP_BUSINESS_ACCOUNT_ID=id_de_la_cuenta_whatsapp_business
WHATSAPP_TEMPLATE_NAME=firma_documento
WHATSAPP_TEMPLATE_LANG=es

# API key for intranet integration
API_KEY=generate_a_random_32_byte_hex_string
# ID del agente usado al enviar via API key (debe existir en tabla agents)
INTRANET_AGENT_ID=1

UPLOADS_DIR=uploads
SIGNED_DIR=signed
CERTIFICATES_DIR=certificates
FORM_UPLOADS_DIR=form-uploads

# ──────────────────────────────────────────────────────────────
# Carta Formulario Service
# ──────────────────────────────────────────────────────────────

# Carpeta con las plantillas PDF de cada NPN (nombre del archivo = nombre del NPN)
PLANTILLAS_DIR=C:\Users\juan.acosta\Desktop\FirmaCloudFronted\firmacloudfrontend\src\assets\Plantillas

# Posición del campo de firma para plantillas NPN (coordenadas PDF en puntos; origen abajo-izquierda)
# Una página carta estándar mide 612 x 792 pt (8.5" x 11" a 72 dpi)
# Ajustar X/Y hasta que la firma quede sobre el campo correcto del PDF
NPN_SIGN_FIELD_X=150
NPN_SIGN_FIELD_Y=130
NPN_SIGN_FIELD_W=200
NPN_SIGN_FIELD_H=50

# Posición de firma para el flujo original (carta-tratamiento-de-datos.pdf)
# No cambiar a menos que se rediseñe el PDF
SIGN_FIELD_X=150
SIGN_FIELD_Y=495
SIGN_FIELD_W=112
SIGN_FIELD_H=32

# Carpeta con los PDFs base de las plantillas para el nuevo flujo send-with-data
DOCUMENT_TEMPLATES_DIR=document-templates

# Posición de firma para el flujo send-with-data (contrato de activación — página 4)
# Solo aplica si getContratoSignConfig() falla al leer src/config/templates/contrato_activacion.json
ACTIVATION_SIGN_FIELD_X=150
ACTIVATION_SIGN_FIELD_Y=130
ACTIVATION_SIGN_FIELD_W=200
ACTIVATION_SIGN_FIELD_H=50

# Base de datos externa (recibe los datos de los formularios)
EXT_DB_HOST=external-mysql-host
EXT_DB_PORT=3306
EXT_DB_USER=ext_user
EXT_DB_PASSWORD=ext_password
EXT_DB_NAME=formularios_db

# Template de WhatsApp para el formulario de actualización de datos
# El template ideal acepta 4 variables: {{1}}=cliente, {{2}}=agente, {{3}}=nombre PDF, {{4}}=URL formulario
# Si falla con 4 params, reintenta con 3 (nombre, agente, url) y luego con 2 (nombre, url)
WHATSAPP_FORM_TEMPLATE_NAME=actualizacion_datos_v5
WHATSAPP_FORM_TEMPLATE_LANG=es

# Poner en "true" si el template tiene un botón CTA de URL configurado en Meta.
# En ese caso se pasa el token como parámetro del botón (el base URL está en la def. del template en Meta).
WHATSAPP_FORM_TEMPLATE_HAS_BUTTON=false

# Timeouts (ms) del transporter SMTP exclusivo del módulo de actualización de datos
# (config/npnEmail.js) — evita que un servidor destino lento (greylisting/antispam
# corporativo) cuelgue un lote de Oleadas por varios minutos. NO afecta el envío del
# flujo original de tratamiento de datos (config/email.js, sin timeouts, sin cambios).
NPN_SMTP_CONNECTION_TIMEOUT_MS=15000
NPN_SMTP_GREETING_TIMEOUT_MS=15000
NPN_SMTP_SOCKET_TIMEOUT_MS=20000

# ──────────────────────────────────────────────────────────────
# Oleadas (envío masivo programado de cartas NPN)
# ──────────────────────────────────────────────────────────────

# Expresión cron del scheduler diario (formato node-cron: min hora dia mes diaSemana)
OLEADA_CRON_SCHEDULE=0 9 * * *
# Timezone usado por node-cron y para calcular el "día" del guard anti-doble-envío
OLEADA_CRON_TIMEZONE=America/Bogota
# Delay (ms) entre cada envío individual dentro de un lote, para no saturar el SMTP de Gmail
OLEADA_SEND_DELAY_MS=3000
# Máximo de filas aceptadas en un archivo de oleada
OLEADA_MAX_RECIPIENTS=5000
# Tamaño máximo (MB) del archivo subido (multer)
OLEADA_UPLOAD_MAX_SIZE_MB=5

# Modo 'drip' (por defecto para oleadas nuevas, ver migration_oleada_drip.sql):
# lotes de tamaño fijo cada N minutos, sin importar el total de destinatarios,
# arrancando de inmediato al crear la oleada.
OLEADA_DRIP_BATCH_SIZE=10
OLEADA_DRIP_INTERVAL_MINUTES=10
# Expresión cron con la que el scheduler revisa si a alguna oleada 'drip' le toca enviar
# (cada oleada solo envía cuando pasaron OLEADA_DRIP_INTERVAL_MINUTES desde su último lote)
OLEADA_DRIP_CHECK_CRON=* * * * *
# Horario laboral (HH:mm, zona OLEADA_CRON_TIMEZONE) en el que el modo 'drip' puede enviar;
# fuera de este rango no se envía nada y se retoma al abrir el horario
OLEADA_BUSINESS_HOURS_START=08:00
OLEADA_BUSINESS_HOURS_END=19:00
